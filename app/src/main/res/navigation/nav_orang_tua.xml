<navigation xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools" android:id="@+id/nav_orang_tua" app:startDestination="@id/nav_home_ortu">
    <!--  HOME ORANG TUA  -->
    <fragment android:id="@+id/nav_home_ortu" android:name="com.example.nutripandacare.fragment.orangtua.HomeOrangTuaFragment" android:label="Home" tools:layout="@layout/fragment_home_orang_tua">
        <action android:id="@+id/action_home_to_gizi" app:destination="@id/nav_gizi"/>
        <action android:id="@+id/action_home_to_menu_mbg" app:destination="@id/nav_menu_mbg"/>
        <action android:id="@+id/action_home_to_edukasi" app:destination="@id/nav_edukasi"/>
        <action android:id="@+id/action_home_to_notifikasi" app:destination="@id/nav_notifikasi_ortu"/>
        <action android:id="@+id/action_home_to_edit_profil_anak" app:destination="@id/nav_edit_profil_anak"/>
        <action android:id="@+id/action_home_to_pengumuman" app:destination="@id/nav_pengumuman"/>
    </fragment>
    <!--  GIZI ANAK  -->
    <fragment android:id="@+id/nav_gizi" android:name="com.example.nutripandacare.fragment.orangtua.GiziFragment" android:label="Gizi Anak" tools:layout="@layout/fragment_gizi">
        <action android:id="@+id/action_gizi_to_input_gizi" app:destination="@id/nav_input_gizi"/>
    </fragment>
    <!--  INPUT GIZI  -->
    <fragment android:id="@+id/nav_input_gizi" android:name="com.example.nutripandacare.fragment.orangtua.InputGiziFragment" android:label="Cek Status Gizi" tools:layout="@layout/fragment_input_gizi"/>
    <!--  MENU MBG KALENDER  -->
    <fragment android:id="@+id/nav_menu_mbg" android:name="com.example.nutripandacare.fragment.orangtua.MenuMbgFragment" android:label="Menu MBG" tools:layout="@layout/fragment_menu_mbg"/>
    <!--  EDUKASI / ARTIKEL  -->
    <fragment android:id="@+id/nav_edukasi" android:name="com.example.nutripandacare.fragment.orangtua.EdukasiFragment" android:label="Edukasi" tools:layout="@layout/fragment_edukasi">
        <action android:id="@+id/action_edukasi_to_preview_konten" app:destination="@id/nav_preview_konten_ortu"/>
    </fragment>
    <!--  PREVIEW KONTEN (orang tua — read only)  -->
    <fragment android:id="@+id/nav_preview_konten_ortu" android:name="com.example.nutripandacare.fragment.guru.PreviewKontenFragment" android:label="Detail Artikel" tools:layout="@layout/fragment_preview_konten">
        <argument android:name="artikel_id" app:argType="string" app:nullable="true" android:defaultValue="@null"/>
    </fragment>
    <!--  NOTIFIKASI ORANG TUA  -->
    <fragment android:id="@+id/nav_notifikasi_ortu" android:name="com.example.nutripandacare.fragment.pengelola.NotifikasiFragment" android:label="Notifikasi" tools:layout="@layout/fragment_notifikasi"/>
    <!--  EDIT PROFIL ANAK  -->
    <fragment android:id="@+id/nav_edit_profil_anak" android:name="com.example.nutripandacare.fragment.orangtua.EditProfilAnakFragment" android:label="Edit Profil Anak" tools:layout="@layout/fragment_edit_profil_anak"/>
    <!--  PENGUMUMAN  -->
    <fragment android:id="@+id/nav_pengumuman" android:name="com.example.nutripandacare.fragment.orangtua.PengumumanFragment" android:label="Pengumuman" tools:layout="@layout/fragment_pengumuman"/>
</navigation>
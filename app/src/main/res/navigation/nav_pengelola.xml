<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_pengelola"
    app:startDestination="@id/fragment_home_pengelola">

    <fragment
        android:id="@+id/fragment_home_pengelola"
        android:name="com.example.nutripandacare.fragment.pengelola.HomePengelolaFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home_pengelola" />

    <fragment
        android:id="@+id/fragment_verifikasi_pengelola"
        android:name="com.example.nutripandacare.fragment.pengelola.DataPenggunaFragment"
        android:label="Verifikasi"
        tools:layout="@layout/fragment_data_pengguna" />

    <fragment
        android:id="@+id/fragment_aduan_pengelola"
        android:name="com.example.nutripandacare.fragment.pengelola.AduanGuruFragment"
        android:label="Aduan"
        tools:layout="@layout/fragment_aduan_guru" />

    <fragment
        android:id="@+id/fragment_menu_mbg"
        android:name="com.example.nutripandacare.fragment.pengelola.KelolaMenuFragment"
        android:label="Menu MBG"
        tools:layout="@layout/fragment_kelola_menu">
        <action
            android:id="@+id/action_fragment_menu_mbg_to_tambahMenuFragment"
            app:destination="@id/tambahMenuFragment" />
    </fragment>

    <fragment
        android:id="@+id/fragment_profil_pengelola"
        android:name="com.example.nutripandacare.fragment.pengelola.NotifikasiFragment"
        android:label="Profil"
        tools:layout="@layout/fragment_notifikasi" />

    <fragment
        android:id="@+id/fragment_notifikasi"
        android:name="com.example.nutripandacare.fragment.pengelola.NotifikasiFragment"
        android:label="Notifikasi"
        tools:layout="@layout/fragment_notifikasi" />

    <fragment
        android:id="@+id/tambahMenuFragment"
        android:name="com.example.nutripandacare.fragment.pengelola.TambahMenuFragment"
        android:label="Tambah Menu"
        tools:layout="@layout/fragment_tambah_menu" />

    <fragment
        android:id="@+id/fragment_rekap_gizi"
        android:name="com.example.nutripandacare.fragment.guru.RekapGiziFragment"
        android:label="Rekap Gizi"
        tools:layout="@layout/fragment_rekap_gizi" />

    <fragment
        android:id="@+id/fragment_edukasi"
        android:name="com.example.nutripandacare.fragment.orangtua.EdukasiFragment"
        android:label="Edukasi"
        tools:layout="@layout/fragment_edukasi" />

</navigation>

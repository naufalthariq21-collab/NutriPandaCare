<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cream_primary"
    android:padding="20dp">

    <!-- Top Row: Back + Progress -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="32dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_card_white"
            android:src="@drawable/ic_back_arrow"
            android:padding="12dp"
            android:contentDescription="@string/back_button"
            android:importantForAccessibility="yes"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_clock_circle"
                android:alpha="0.4"
                android:layout_marginEnd="5dp"/>
            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_clock_circle"
                android:alpha="0.4"
                android:layout_marginEnd="5dp"/>
            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_success_circle"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/pilih_peran"
        android:textSize="26sp"
        android:textColor="@color/green_dark"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:layout_gravity="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/pilih_peran_subtitle"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_gravity="center"
        android:gravity="center"
        android:layout_marginBottom="32dp"/>

    <!-- Role Card: Orang Tua -->
    <LinearLayout
        android:id="@+id/cardOrangTua"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@drawable/selector_role_card"
        android:layout_marginBottom="14dp"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_role_icon"
            android:layout_marginEnd="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👨‍👩‍👧"
                android:textSize="24sp"
                android:layout_gravity="center"
                android:importantForAccessibility="no"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/orang_tua"
                android:textSize="16sp"
                android:textColor="@color/green_dark"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/orang_tua_desc"
                android:textSize="12sp"
                android:textColor="@color/text_body"
                android:lineSpacingMultiplier="1.3"/>
        </LinearLayout>

        <View
            android:id="@+id/radioOrangTua"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:background="@drawable/bg_role_icon"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

    <!-- Role Card: Guru -->
    <LinearLayout
        android:id="@+id/cardGuru"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@drawable/selector_role_card"
        android:layout_marginBottom="14dp"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_role_icon"
            android:layout_marginEnd="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👩‍🏫"
                android:textSize="24sp"
                android:layout_gravity="center"
                android:importantForAccessibility="no"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/guru"
                android:textSize="16sp"
                android:textColor="@color/green_dark"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/guru_desc"
                android:textSize="12sp"
                android:textColor="@color/text_body"
                android:lineSpacingMultiplier="1.3"/>
        </LinearLayout>

        <View
            android:id="@+id/radioGuru"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:background="@drawable/bg_clock_circle"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

    <!-- Role Card: Pengelola MBG -->
    <LinearLayout
        android:id="@+id/cardPengelola"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@drawable/selector_role_card"
        android:layout_marginBottom="32dp"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_role_icon"
            android:layout_marginEnd="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏛️"
                android:textSize="24sp"
                android:layout_gravity="center"
                android:importantForAccessibility="no"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pengelola_mbg"
                android:textSize="16sp"
                android:textColor="@color/green_dark"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pengelola_mbg_desc"
                android:textSize="12sp"
                android:textColor="@color/text_body"
                android:lineSpacingMultiplier="1.3"/>
        </LinearLayout>

        <View
            android:id="@+id/radioPengelola"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:background="@drawable/bg_clock_circle"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Lanjutkan Button -->
    <Button
        android:id="@+id/btnLanjutkan"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="16dp"
        android:text="@string/lanjutkan"
        android:textSize="16sp"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:background="@drawable/bg_button_primary"/>

</LinearLayout>
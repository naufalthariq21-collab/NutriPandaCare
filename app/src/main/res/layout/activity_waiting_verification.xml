<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="@color/cream_primary" android:padding="20dp">
    <!--  Top Row: Back + Progress  -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp" android:layout_marginBottom="40dp">
        <ImageButton android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_card_white" android:src="@drawable/ic_back_arrow" android:padding="8dp"/>
        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
            <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/bg_clock_circle" android:alpha="0.4" android:layout_marginEnd="5dp"/>
            <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/bg_clock_circle" android:alpha="0.4" android:layout_marginEnd="5dp"/>
            <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/bg_success_circle"/>
        </LinearLayout>
    </LinearLayout>
    <!--  Clock Icon Circle  -->
    <FrameLayout android:layout_width="120dp" android:layout_height="120dp" android:background="@drawable/bg_clock_circle" android:layout_gravity="center" android:layout_marginBottom="28dp">
        <ImageView android:layout_width="56dp" android:layout_height="56dp" android:src="@drawable/ic_clock" android:layout_gravity="center"/>
    </FrameLayout>
    <!--  Title  -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/menunggu_verifikasi" android:textSize="24sp" android:textColor="@color/green_dark" android:textStyle="bold" android:fontFamily="sans-serif-medium" android:layout_gravity="center" android:layout_marginBottom="12dp"/>
    <!--  Description  -->
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/verifikasi_desc" android:textSize="14sp" android:textColor="@color/text_secondary" android:gravity="center" android:lineSpacingMultiplier="1.5" android:layout_marginBottom="36dp" android:paddingStart="16dp" android:paddingEnd="16dp"/>
    <!--  Status Card  -->
    <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardCornerRadius="16dp" app:cardElevation="4dp" app:cardBackgroundColor="@color/white" android:layout_marginBottom="8dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
            <!--  Status Row  -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/status_label" android:textSize="14sp" android:textColor="@color/text_secondary"/>
                <!--  Pending Badge  -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/pending" android:textSize="12sp" android:textColor="#856404" android:textStyle="bold" android:background="@drawable/bg_pending_badge" android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="4dp" android:paddingBottom="4dp"/>
            </LinearLayout>
            <!--  Divider  -->
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginBottom="16dp"/>
            <!--  Peran Row  -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/peran_label" android:textSize="14sp" android:textColor="@color/text_secondary"/>
                <TextView android:id="@+id/tvSelectedRole" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/guru" android:textSize="14sp" android:textColor="@color/green_dark" android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <!--  Info Card: 1-2 hari kerja  -->
    <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardCornerRadius="12dp" app:cardElevation="0dp" app:cardBackgroundColor="@color/green_pale" android:layout_marginBottom="32dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ℹ️" android:textSize="16sp" android:layout_marginEnd="10dp"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Tim admin akan memproses verifikasi dalam 1-2 hari kerja" android:textSize="12sp" android:textColor="@color/green_dark" android:lineSpacingMultiplier="1.4"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <!--  Spacer  -->
    <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
    <!--  Kembali ke Login Button  -->
    <Button android:id="@+id/btnKembaliLogin" android:layout_width="match_parent" android:layout_height="54dp" android:text="@string/kembali_ke_login" android:textSize="16sp" android:textColor="@color/white" android:textStyle="bold" android:background="@drawable/bg_button_primary" android:layout_marginBottom="16dp"/>
</LinearLayout>
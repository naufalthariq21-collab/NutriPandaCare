<!--  activity_kelola_pengguna.xml  -->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/cream_primary">
    <!--  TOP APP BAR  -->
    <com.google.android.material.appbar.AppBarLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@color/green_dark" app:elevation="4dp">
        <androidx.appcompat.widget.Toolbar android:id="@+id/toolbar" android:layout_width="match_parent" android:layout_height="?attr/actionBarSize" android:paddingHorizontal="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kelola Data Pengguna" android:textColor="@color/white" android:textSize="18sp" android:textStyle="bold" android:layout_gravity="start"/>
        </androidx.appcompat.widget.Toolbar>
        <!--  Search Bar below toolbar  -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" android:background="@color/green_primary">
            <com.google.android.material.textfield.TextInputLayout style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:layout_width="match_parent" android:layout_height="wrap_content" app:boxBackgroundColor="@color/white" app:boxStrokeColor="@color/white" app:boxCornerRadiusTopStart="24dp" app:boxCornerRadiusTopEnd="24dp" app:boxCornerRadiusBottomStart="24dp" app:boxCornerRadiusBottomEnd="24dp" app:startIconDrawable="@drawable/ic_search" app:startIconTint="@color/text_hint">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/etSearch" android:layout_width="match_parent" android:layout_height="42dp" android:hint="Cari pengguna..." android:textSize="14sp" android:textColor="@color/text_primary" android:inputType="textPersonName"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" app:layout_behavior="@string/appbar_scrolling_view_behavior">
        <!--  Filter Chips  -->
        <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content" android:scrollbars="none" android:paddingHorizontal="12dp" android:paddingVertical="10dp" android:background="@color/cream_primary">
            <com.google.android.material.chip.ChipGroup android:id="@+id/chipGroupFilter" android:layout_width="wrap_content" android:layout_height="wrap_content" app:singleSelection="true" app:selectionRequired="true">
                <com.google.android.material.chip.Chip android:id="@+id/chipSemua" style="@style/Widget.MaterialComponents.Chip.Choice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Semua" android:checked="true" android:textColor="@color/chip_green_text" app:chipBackgroundColor="@color/chip_green_bg" app:chipStrokeColor="@color/green_accent" app:chipStrokeWidth="1dp"/>
                <com.google.android.material.chip.Chip android:id="@+id/chipMenunggu" style="@style/Widget.MaterialComponents.Chip.Choice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Menunggu Verifikasi" android:textColor="@color/text_secondary" app:chipBackgroundColor="@color/surface_light" app:chipStrokeColor="@color/border_medium" app:chipStrokeWidth="1dp"/>
                <com.google.android.material.chip.Chip android:id="@+id/chipTerverifikasi" style="@style/Widget.MaterialComponents.Chip.Choice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Terverifikasi" android:textColor="@color/text_secondary" app:chipBackgroundColor="@color/surface_light" app:chipStrokeColor="@color/border_medium" app:chipStrokeWidth="1dp"/>
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>
        <!--  User List  -->
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvUserList" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:padding="12dp" android:clipToPadding="false" android:paddingBottom="80dp"/>
    </LinearLayout>
    <!--  BOTTOM NAVIGATION  -->
    <com.google.android.material.bottomnavigation.BottomNavigationView android:id="@+id/bottomNav" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="bottom" android:background="@color/white" app:itemIconTint="@color/nav_inactive" app:itemTextColor="@color/nav_inactive" app:menu="@menu/bottom_nav_pengelola" app:elevation="8dp"/>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
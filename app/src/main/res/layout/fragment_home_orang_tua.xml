<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ══════════════════════════════════ -->
        <!-- HEADER HIJAU GELAP                -->
        <!-- ══════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/green_dark"
            app:cardCornerRadius="0dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Baris: Salam + Tombol Notifikasi -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <!-- Teks salam -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Halo,"
                            android:textColor="@color/green_light"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tv_nama_bunda"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bunda!"
                            android:textColor="@color/white"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Tombol Notifikasi -->
                    <!-- bg_user_avatar = oval shape, warna gelap -->
                    <FrameLayout
                        android:id="@+id/btn_notifikasi"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_user_avatar"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_popup_reminder"
                            app:tint="@color/white" />

                        <!-- Badge merah: bg_pending_badge = oval merah -->
                        <TextView
                            android:id="@+id/tv_badge_notif"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="top|end"
                            android:background="@drawable/bg_pending_badge"
                            android:gravity="center"
                            android:text="3"
                            android:textColor="@color/white"
                            android:textSize="9sp"
                            android:visibility="visible" />

                    </FrameLayout>

                </LinearLayout>

                <!-- Latest Activity Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/green_primary"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Latest Activity + Today -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="6dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Latest Activity"
                                android:textColor="@color/green_light"
                                android:textSize="11sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Today"
                                android:textColor="@color/green_light"
                                android:textSize="11sp" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Menu Hari Ini"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tv_menu_hari_ini"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nasi + Ayam tersedia untuk Anak"
                            android:textColor="@color/green_pale"
                            android:textSize="13sp"
                            android:layout_marginBottom="12dp" />

                        <!-- Progress Nutrisi -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">

                            <!-- ic_clock sudah ada di drawable project -->
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_clock"
                                app:tint="@color/green_light"
                                android:layout_marginEnd="8dp" />

                            <ProgressBar
                                android:id="@+id/progress_nutrisi"
                                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                                android:layout_width="0dp"
                                android:layout_height="6dp"
                                android:layout_weight="1"
                                android:max="100"
                                android:progress="75"
                                android:progressTint="@color/green_pale"
                                android:progressBackgroundTint="@color/green_medium" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nutrisi terpenuhi 75%"
                            android:textColor="@color/green_light"
                            android:textSize="11sp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════════════════════════════ -->
        <!-- KONTEN BAWAH                      -->
        <!-- ══════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── Quick Actions ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Actions"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <!-- Jadwal Menu -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_jadwal_menu"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@android:drawable/ic_menu_agenda"
                            app:tint="@color/green_primary" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jadwal Menu"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:gravity="center"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Cek Gizi -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_cek_gizi"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@android:drawable/ic_menu_recent_history"
                            app:tint="@color/green_primary" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cek Gizi"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:gravity="center"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Edukasi Gizi -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_edukasi_gizi"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@android:drawable/ic_menu_help"
                            app:tint="@color/green_primary" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Edukasi Gizi"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:gravity="center"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ── Profil Anak ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profil Anak"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/card_profil_anak"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <!-- Avatar: bg_user_avatar (oval) sudah ada di project -->
                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_user_avatar"
                        android:layout_marginEnd="14dp">
                        <ImageView
                            android:id="@+id/iv_foto_anak"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:src="@android:drawable/ic_menu_myplaces"
                            app:tint="@color/green_light"
                            android:scaleType="centerCrop" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_nama_anak"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Zainal"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/tv_info_anak"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="11 Tahun • Laki Laki"
                            android:textSize="13sp"
                            android:textColor="@color/text_hint" />

                    </LinearLayout>

                    <!-- Panah kanan: ic_back_arrow dirotasi 180° (ic_back_arrow ada di project) -->
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_back_arrow"
                        android:rotation="180"
                        app:tint="@color/divider" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
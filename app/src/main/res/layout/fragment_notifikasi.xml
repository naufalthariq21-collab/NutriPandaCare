<?xml version="1.0" encoding="utf-8"?>
<!-- activity_buat_notifikasi.xml -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream_primary">

    <!-- TOP APP BAR -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/green_dark"
        app:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingHorizontal="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Buat Notifikasi"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_gravity="start"/>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:paddingBottom="80dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- TARGET AUDIENCE CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Target Audience"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <!-- Chips for audience selection -->
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupAudience"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:selectionRequired="true"
                        app:singleSelection="false">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipSemuaGuru"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Semua Guru"
                            android:textColor="@color/chip_green_text"
                            app:chipBackgroundColor="@color/chip_green_bg"
                            app:chipStrokeColor="@color/green_accent"
                            app:chipStrokeWidth="1dp"
                            android:checked="true"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipOrangTua"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Orang Tua"
                            android:textColor="@color/text_secondary"
                            app:chipBackgroundColor="@color/surface_light"
                            app:chipStrokeColor="@color/border_medium"
                            app:chipStrokeWidth="1dp"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipKelas1A"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kelas 1A"
                            android:textColor="@color/text_secondary"
                            app:chipBackgroundColor="@color/surface_light"
                            app:chipStrokeColor="@color/border_medium"
                            app:chipStrokeWidth="1dp"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipKelas2B"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kelas 2B"
                            android:textColor="@color/text_secondary"
                            app:chipBackgroundColor="@color/surface_light"
                            app:chipStrokeColor="@color/border_medium"
                            app:chipStrokeWidth="1dp"/>
                    </com.google.android.material.chip.ChipGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- PESAN NOTIFIKASI CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pesan Notifikasi"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPesanNotif"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxStrokeColor="@color/input_border"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPesanNotif"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Tulis pesan notifikasi di sini..."
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:minLines="4"
                            android:maxLines="8"
                            android:gravity="top"
                            android:inputType="textMultiLine|textCapSentences"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- PREVIEW NOTIFIKASI CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Preview Notifikasi"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <!-- Phone mockup container -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:background="@drawable/bg_phone_mockup">

                        <!-- Notification preview inside mockup -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:orientation="vertical"
                            android:background="@drawable/bg_notif_preview"
                            android:padding="12dp"
                            android:layout_margin="30dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="4dp">

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/logo_nutripanda"
                                    android:layout_marginEnd="6dp"
                                    android:contentDescription="icon"/>

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="NutriPanda Care"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="now"
                                    android:textColor="@color/text_hint"
                                    android:textSize="10sp"/>
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvNotifPreview"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Tulis pesan notifikasi di sini..."
                                android:textColor="@color/text_body"
                                android:textSize="12sp"
                                android:maxLines="3"
                                android:ellipsize="end"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|center_horizontal"
                            android:layout_marginBottom="8dp"
                            android:text="Smartphone Preview"
                            android:textColor="@color/text_hint"
                            android:textSize="10sp"/>
                    </FrameLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- KIRIM BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnKirimNotif"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🔔  Kirim Notifikasi"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@color/green_dark"
                app:cornerRadius="12dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- BOTTOM NAVIGATION -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/nav_bg"
        app:itemIconTint="@color/nav_active"
        app:itemTextColor="@color/nav_inactive"
        app:itemActiveIndicatorColor="@color/nav_indicator"
        app:menu="@menu/bottom_nav_pengelola"
        app:elevation="8dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>